{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@worksuite/shared-types": ["./packages/shared-types/src/index.ts"],
      "@worksuite/i18n":         ["./packages/i18n/src/index.ts"],
      "@worksuite/ui":           ["./packages/ui/src/index.ts"],
      "@worksuite/jira-client":  ["./packages/jira-client/src/index.ts"]
    }
  },
  "references": [
    { "path": "./packages/shared-types" },
    { "path": "./packages/i18n"         },
    { "path": "./packages/ui"           },
    { "path": "./packages/jira-client"  },
    { "path": "./apps/web"              },
    { "path": "./apps/api"              }
  ],
  "include": []
}
