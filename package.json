{
  "name": "worksuite",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm -w apps/web run dev",
    "dev:api": "npm -w apps/api run dev",
    "build": "npm -w apps/web run build",
    "build:web": "npm -w apps/web run build",
    "build:api": "npm -w apps/api run build",
    "typecheck": "tsc --build --verbose",
    "lint": "eslint packages apps --ext .ts,.tsx"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
